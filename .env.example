ENVIRONMENT=dev
CONFIG_FILE=configs/dev.yaml
LOG_LEVEL=INFO

# Live order placement is impossible unless both are true.
TRADING__LIVE_TRADING=false
TRADING__LIVE_TRADING_ACKNOWLEDGED=false
TRADING__TINY_LIVE_MODE=true
TRADING__TINY_LIVE_MAX_ORDER_SIZE=1

POLYMARKET__PRIVATE_KEY=0x...
POLYMARKET__API_KEY=...
POLYMARKET__SECRET=...
POLYMARKET__PASSPHRASE=...
POLYMARKET__FUNDER_ADDRESS=0x...
POLYMARKET__SIGNATURE_TYPE=1
POLYMARKET__DERIVE_API_CREDS=false

DATABASE__URL=postgresql+asyncpg://polymarket:polymarket@postgres:5432/polymarket
ADMIN__TOKEN=change-me-long-random-token

ALERTS__TELEGRAM_ENABLED=false
ALERTS__TELEGRAM_BOT_TOKEN=
ALERTS__TELEGRAM_CHAT_ID=
ALERTS__EMAIL_ENABLED=false
ALERTS__SMTP_HOST=
ALERTS__SMTP_PORT=587
ALERTS__SMTP_USERNAME=
ALERTS__SMTP_PASSWORD=
ALERTS__EMAIL_FROM=
ALERTS__EMAIL_TO=[]
